{
    "system": {
        "device_id": "YOUR_DEVICE_ID",
        "password": "YOUR_DEVICE_PASSWORD",
        "user_id": "YOUR_USER_ID",
        "boot_time": null,
        "model": "raspberry_pi",
        "version": "1.0.0",
        "log_level": "DEBUG",
        "status": "offline",
        "last_update": null
    },
    "wake_word": {
        "enabled": true,
        "api_key": "YOUR_PICOVOICE_API_KEY",
        "keyword_path": "wakeword_source/your_wake_word_pi.ppn",
        "sensitivity": 0.5
    },
    "audio_settings": {
        "sample_rate": 24000,
        "channels": 1,
        "chunk_size": 960,
        "format": "int16",
        "general_volume": 20,
        "music_volume": 50,
        "notification_volume": 50,
        "wake_sound_path": "sound/pvwake.wav"
    },
    "mqtt": {
        "broker": "broker.emqx.io",
        "port": 1883,
        "username": null,
        "password": null,
        "client_id_prefix": "YOUR_CLIENT_ID_PREFIX",
        "topic_prefix": "YOUR_TOPIC_PREFIX"
    },
    "network": {
        "server_ip": "YOUR_SERVER_IP",
        "server_udp_port": 8884,
        "server_udp_receive_port": 8885,
        "stt_bridge_ip": null,
        "stt_bridge_port": 8884,
        "discovery_port": 50000,
        "discovery_request": "DISCOVER_SERVER_REQUEST",
        "discovery_response_prefix": "DISCOVER_SERVER_RESPONSE_",
        "stt_mode": false
    },
    "recording": {
        "auto_stop": true,
        "timeout": 15.0,
        "silence_threshold": 300,
        "initial_silence_duration": 3.0,
        "speech_silence_duration": 1.0,
        "save_path": "recordings"
    },
    "debug": {
        "enabled": false
    }
}
